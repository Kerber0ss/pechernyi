{
  "name": "pechernyi",
  "description": "Ultra-compressed communication mode. Cuts ~75% of tokens while keeping full technical accuracy by speaking like a pechernyi.",
  "author": {
    "name": "Kerber0ss",
    "url": "https://github.com/Kerber0ss"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/pechernyi-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading pechernyi mode..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/pechernyi-mode-tracker.js\"",
            "timeout": 5,
            "statusMessage": "Tracking pechernyi mode..."
          }
        ]
      }
    ]
  }
}
